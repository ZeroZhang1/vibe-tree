{
  "name": "vibe-tree",
  "version": "0.5.1",
  "productName": "Vibe Tree",
  "private": true,
  "type": "module",
  "description": "A floating desktop token weather tree for vibe coding.",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.electron.json && node scripts/copy-preload.mjs && vite build",
    "edit:achievements": "node scripts/achievement-copy-editor.mjs",
    "smoke:electron": "node scripts/smoke-electron.mjs",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.json --noEmit",
    "start": "npm run build && electron dist/electron/main.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "qrcode": "^1.5.4"
  }
}
